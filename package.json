{
  "name": "clone-tabnews",
  "version": "1.0.0",
  "description": "Implementação do tabnews.com.br para o https://curso.dev",
  "main": "index.js",
  "scripts": {
    "dev": "npm run services:up && next dev",
    "services:up": "docker compose -f infra/compose.yaml --env-file .env up -d",
    "services:stop": "docker compose -f infra/compose.yaml --env-file .env stop",
    "services:down": "docker compose -f infra/compose.yaml --env-file .env down",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watchAll"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "next": "^13.5.11",
    "pg": "^8.11.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "prettier": "^3.6.2"
  }
}
